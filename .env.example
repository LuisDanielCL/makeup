# Copia este archivo a ".env" y rellena tus datos.

# Número de WhatsApp en formato internacional SIN "+", espacios ni guiones.
# Ejemplo para México: 521XXXXXXXXXX  |  Chile: 569XXXXXXXX
VITE_WHATSAPP_NUMBER=521XXXXXXXXXX

# ID de tu Google Sheet (lo que va entre /d/ y /edit en la URL del Sheet).
# Ejemplo de URL: https://docs.google.com/spreadsheets/d/AQUI_VA_EL_ID/edit
VITE_SHEET_ID=

# Nombre del estudio (aparece en el sitio).
VITE_BRAND_NAME=Estudio de Maquillaje
